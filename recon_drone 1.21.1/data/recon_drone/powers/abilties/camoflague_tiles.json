    "name": "Camoflague tiles",
    "description": "An interconnected weave of hexegon shaped tiles across your surface enables you to go invisible when not moving or partially invisible when moving and crouching, Being hit disables invisibility.",
    "type": "origins:multiple",
    "timer": {
        "type": "origins:resource",
        "min": 0,
        "max": 20,
        "start_value": 20,
        "hud_render": {
            "should_render": false
        }
    },
    "cooldown": {
        "type": "origins:cooldown",
        "cooldown": 200,
        "hud_render": {
            "should_render": false,
            "sprite_location": "origins:textures/gui/community/huang/resource_bar_01.png",
            "bar_index": 20,
            "inverted": true
        }
    },
    "damage_condition": {
        "type": "origins:amount",
        "comparison": ">=",
        "compare_to": 1
    },
    "self_action": {
        "type": "origins:and",
        "actions": [
            {
                "type": "origins:trigger_cooldown",
                "power": "*:*_cooldown"
            },
            {
                "type": "origins:change_resource",
                "resource": "*:*_timer",
                "change": 20,
                "operation": "set"
            }
        ]
    },
    "drain_and_fill": {
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_cooldown",
            "comparison": "==",
            "compare_to": 0
        },
        "type": "origins:action_over_time",
        "interval": 1,
        "entity_action": {
            "type": "origins:if_else",
            "condition": {
                "type": "origins:and",
                "conditions": [
                    {
                        "type": "origins:moving"
                    },
                    {
                        "type": "origins:sneaking"
                    }
                ]
            },
            "if_action": {
                "type": "origins:if_else",
                "condition": {
                    "type": "origins:resource",
                    "resource": "*:*_timer",
                    "comparison": "<",
                    "compare_to": 5
                },
                "if_action": {
                    "type": "origins:change_resource",
                    "resource": "*:*_timer",
                    "change": 1,
                    "operation": "add"
                },
                "else_action": {
                    "type": "origins:if_else",
                    "condition": {
                        "type": "origins:resource",
                        "resource": "*:*_timer",
                        "comparison": ">",
                        "compare_to": 5
                    },
                    "if_action": {
                        "type": "origins:change_resource",
                        "resource": "*:*_timer",
                        "change": -1,
                        "operation": "add"
                    }
                }
            },
            "else_action": {
                "type": "origins:if_else",
                "condition": {
                    "type": "origins:moving"
                },
                "if_action": {
                    "type": "origins:change_resource",
                    "resource": "*:*_timer",
                    "change": 3,
                    "operation": "add"
                },
                "else_action": {
                    "type": "origins:change_resource",
                    "resource": "*:*_timer",
                    "change": -2,
                    "operation": "add"
                }
            }
        }
    },
    "invis": {
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_timer",
            "comparison": "==",
            "compare_to": 0
        },
        "type": "origins:invisibility",
        "render_armor": false,
        "render_outline": false
    }
}